---
layout: default
---
<div class="post cv">
  <header class="post-header">
    <h1 class="post-title">
      {{ page.title }}
      {% if page.cv_pdf %}
        <a
          href="{{ page.cv_pdf | prepend: 'assets/pdf/' | relative_url}}"
          target="_blank"
          rel="noopener noreferrer"
          class="float-right"
          ><i class="fa-solid fa-file-pdf"></i
        ></a>
      {% endif %}
    </h1>
    {% if page.description %}
      <p class="post-description">{{ page.description }}</p>
    {% endif %}
  </header>

  {% for entry in site.data.cv %}
    <div class="card mt-3 p-3">
      <div class="row">
        <div class="col">
          <h3 class="card-title font-weight-medium">{{ entry.title }}</h3>
        </div>
      </div>
      {% if entry.type == "time_table" %}
        {% include cv/time_table.liquid entry=entry %}
      {% elsif entry.type == "map" %}
        {% include cv/map.liquid entry=entry %}
      {% elsif entry.type == "nested_list" %}
        {% include cv/nested_list.liquid entry=entry %}
      {% elsif entry.type == "list" %}
        {% include cv/list.liquid entry=entry %}
      {% elsif entry.type == "list_groups" %}
        {% include cv/list_groups.liquid entry=entry %}
      {% endif %}
    </div>
  {% endfor %}
</div>
